{
  "name": "qodeloc-mcp-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/qodeloc-mcp-adapter.js --sourcemap",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "prestart": "npm run bundle",
    "start": "node dist/qodeloc-mcp-adapter.js",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "node-fetch": "^3.3.2",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.1.0",
    "esbuild": "^0.25.8",
    "eslint": "^9.30.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0"
  }
}
