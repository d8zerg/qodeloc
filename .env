# QodeLoc local defaults

# Core runtime
QODELOC_EMBEDDER_HOST=127.0.0.1
QODELOC_EMBEDDER_PORT=8080
QODELOC_EMBEDDER_API_PATH=/v1/embeddings
QODELOC_EMBEDDER_MODEL=qodeloc-embedding
QODELOC_EMBEDDER_BATCH_SIZE=8
QODELOC_EMBEDDER_TIMEOUT_MS=30000

QODELOC_LLM_HOST=127.0.0.1
QODELOC_LLM_PORT=4000
QODELOC_LLM_API_PATH=/v1/chat/completions
QODELOC_LLM_MODEL=balanced
QODELOC_LLM_API_KEY=sk-qodeloc-dev
QODELOC_LLM_MAX_TOKENS=96
QODELOC_LLM_TIMEOUT_MS=30000
QODELOC_LLM_MAX_RETRIES=3
QODELOC_LLM_INITIAL_BACKOFF_MS=150
QODELOC_LLM_MAX_BACKOFF_MS=2000

QODELOC_PROMPTS_DIR=prompts
QODELOC_PROMPT_CONTEXT_TOKEN_LIMIT=3072
QODELOC_PROMPT_MODULE_LIMIT=4
QODELOC_PROMPT_SYMBOL_LIMIT=8
QODELOC_PROMPT_LOCAL_FILE_LIMIT=3
QODELOC_PROMPT_MODULE_TOKEN_LIMIT=256
QODELOC_PROMPT_SYMBOL_TOKEN_LIMIT=1024
QODELOC_PROMPT_LOCAL_FILE_TOKEN_LIMIT=768

QODELOC_HIERARCHY_MODULE_TOP_K=3
QODELOC_HIERARCHY_SYMBOL_TOP_K=5
QODELOC_HIERARCHY_PUBLIC_SYMBOL_LIMIT=12

QODELOC_RETRIEVER_RELATED_SYMBOL_LIMIT=4
QODELOC_RETRIEVER_CONTEXT_TOKEN_LIMIT=256

QODELOC_API_HOST=127.0.0.1
QODELOC_API_PORT=3100
QODELOC_API_MAX_BODY_BYTES=1048576
QODELOC_API_TIMEOUT_MS=30000

QODELOC_INDEXER_EMBEDDING_BATCH_SIZE=8
QODELOC_INDEXER_RECURSIVE=true
QODELOC_INDEXER_SOURCE_EXTENSIONS=.cpp,.cxx,.cc,.h,.hpp,.hxx
QODELOC_GIT_BASE_REF=HEAD~1

# Storage defaults to in-memory; set a path to persist the DuckDB file.
QODELOC_STORAGE_DB_PATH=

# Dev stack / compose wiring
QODELOC_QDRANT_HTTP_PORT=6333
QODELOC_QDRANT_GRPC_PORT=6334
QODELOC_LLAMA_PORT=8080
QODELOC_LLAMA_THREADS=8
QODELOC_LLAMA_THREADS_BATCH=8
QODELOC_LITELLM_PORT=4000
QODELOC_LITELLM_MASTER_KEY=sk-qodeloc-dev
QODELOC_LLAMA_MODEL_DIR=models/downloads/llama31-8b
QODELOC_LLAMA_MODEL_FILE=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
